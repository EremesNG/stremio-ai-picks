# ==============================================================================
# stremio-ai-picks — Environment Variables
# ==============================================================================
# Copia este archivo como `.env` y completa los valores reales.
# NO subas tu `.env` al repositorio — ya está en .gitignore.
#
# Nota importante sobre API keys de usuario final:
# Las API keys de Google Gemini y TMDB NO se configuran aquí. Cada usuario
# del addon las introduce en la página `/configure` del propio addon. Se
# cifran con ENCRYPTION_KEY (AES-256-CBC) y viajan como segmento cifrado
# en la URL del manifest. Ver `utils/crypto.js` y `public/configure.html`.
# ==============================================================================


# ------------------------------------------------------------------------------
# Core & Seguridad (OBLIGATORIAS — el servidor no arranca sin estas)
# ------------------------------------------------------------------------------

# Clave de cifrado AES-256-CBC para la configuración de usuario.
# REQUISITO: mínimo 32 caracteres. El proceso termina (process.exit) si falta
# o es más corta. Genera una segura con: `openssl rand -hex 32`
ENCRYPTION_KEY=

# Dominio público del addon.
# Si no incluyes protocolo, se asume `https://`.
# Para desarrollo local puedes usar explícitamente `http://127.0.0.1:3000`.
# Ejemplos: `mi-addon.example.com`, `localhost:3000` (dev), `http://127.0.0.1:3000` (dev).
HOST=


# ------------------------------------------------------------------------------
# Trakt.tv OAuth (OBLIGATORIAS para que funcione la integración con Trakt)
# ------------------------------------------------------------------------------
# Crea una aplicación OAuth en https://trakt.tv/oauth/applications
# Redirect URI debe coincidir con: https://${HOST}/callback

TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=


# ------------------------------------------------------------------------------
# Turso (LibSQL) — Database (REQUIRED for Vercel deployment)
# ------------------------------------------------------------------------------
# Connection URI for your Turso database.
# Get your URI at https://turso.tech/
TURSO_URI=libsql://your-database.turso.io

# Authentication token for Turso.
# Generate a token in the Turso dashboard.
TURSO_TOKEN=your-turso-auth-token


# ------------------------------------------------------------------------------
# APIs externas opcionales (mejoran la experiencia del usuario)
# ------------------------------------------------------------------------------

# Rating Poster DB — añade overlays de ratings sobre los posters.
# Obtén tu key en https://ratingposterdb.com/
RPDB_API_KEY=

# Fanart.tv — permite obtener arte adicional (logos, clearart, etc.).
# Obtén tu key en https://fanart.tv/get-an-api-key/
FANART_API_KEY=


# ------------------------------------------------------------------------------
# Administración y mantenimiento (OPCIONALES pero recomendadas en producción)
# ------------------------------------------------------------------------------

# Token para proteger los endpoints de administración de caché (/cache/*).
# Si no lo defines, el valor por defecto es inseguro: "change-me-in-env-file".
# CÁMBIALO en cualquier entorno público.
ADMIN_TOKEN=change-me-in-env-file

# Logging verboso. Debe ser EXACTAMENTE la cadena "true" para activarse.
# Cualquier otro valor (1, yes, on) se interpreta como false.
ENABLE_LOGGING=false


# ------------------------------------------------------------------------------
# Reporte de issues desde la UI (OPCIONALES — solo si habilitas el formulario)
# ------------------------------------------------------------------------------

# Personal Access Token de GitHub con permiso `repo` o `public_repo`.
# Permite al addon crear issues automáticamente en el repo configurado.
GITHUB_TOKEN=

# Secret key de Google reCAPTCHA v2/v3 para validar el formulario de issues
# y evitar spam. Obtenla en https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET_KEY=
